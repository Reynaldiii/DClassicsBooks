<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="#E2D8C0"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="82dp"
            android:layout_height="match_parent"
            app:cardCornerRadius="5dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/secondary_color"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/imgTopBookCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Top book cover" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTopBookTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/noto_serif_bold"
                android:maxLines="1"
                android:textColor="@color/card_dark"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTopBookAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:fontFamily="@font/manrope_regular"
                android:maxLines="1"
                android:textColor="#534E48"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvTopBookDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:fontFamily="@font/manrope_regular"
                android:maxLines="3"
                android:textColor="#282724"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvTopBookReadMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Read more"
                android:textColor="@color/secondary_color"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

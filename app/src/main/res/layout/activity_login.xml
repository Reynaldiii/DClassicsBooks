<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:padding="24dp"
    tools:context=".LoginActivity">

    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_logo" /> <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D'Classics Books"
            android:textColor="@color/primary_color"
            android:textSize="36sp"
            android:fontFamily="@font/noto_serif_bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIMELESS WISDOM IN YOUR POCKET"
            android:textColor="@color/secondary_color"
            android:alpha="0.8"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:fontFamily="@font/manrope_regular"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/formSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/headerSection">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USERNAME"
            style="@style/Captions"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/ic_person"
            app:startIconTint="#888888"
            app:hintEnabled="false"
            app:boxBackgroundMode="none">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter your username"
                android:textColorHint="#AAAAAA"
                style="@style/Placeholder"
                android:background="@drawable/bg_rounded_input"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textColor="@color/dark_text"
            style="@style/Captions"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="#888888"
            app:endIconMode="password_toggle"
            app:endIconTint="#888888"
            app:hintEnabled="false"
            app:boxBackgroundMode="none">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter your password"
                android:textColorHint="#AAAAAA"
                style="@style/Placeholder"
                android:background="@drawable/bg_rounded_input"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:inputType="textPassword"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textColor="@color/secondary_color"
            style="@style/Captions"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="SIGN IN"
        android:textColor="@color/light_text"
        style="@style/ButtonLabels"
        app:backgroundTint="@color/btn_login_selector"
        app:cornerRadius="30dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/formSection"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—  Fine Literature for the Modern Age  —"
        android:textStyle="italic"
        android:textColor="@color/dark_text"
        style="@style/Captions"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".HomeActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:paddingBottom="28dp">

            <View
                android:id="@+id/blueHeaderBg"
                android:layout_width="match_parent"
                android:layout_height="292dp"
                android:background="@drawable/bg_header_curved"
                app:layout_constraintTop_toTopOf="parent" />

            <include
                android:id="@+id/homeHeader"
                layout="@layout/layout_app_header"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/topCarouselContainer"
                android:layout_width="match_parent"
                android:layout_height="205dp"
                android:layout_marginTop="70dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:id="@+id/topBookStage"
                    android:layout_width="match_parent"
                    android:layout_height="174dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    app:layout_constraintBottom_toTopOf="@id/topBookDots"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btnPrevTop"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="58dp"
                    android:background="@drawable/bg_circle_button"
                    android:contentDescription="Previous featured book"
                    android:elevation="8dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_chevron_left"
                    app:layout_constraintBottom_toBottomOf="@id/topBookStage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/topBookStage"
                    app:tint="@color/primary_color" />

                <ImageButton
                    android:id="@+id/btnNextTop"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="58dp"
                    android:background="@drawable/bg_circle_button"
                    android:contentDescription="Next featured book"
                    android:elevation="8dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_chevron_right"
                    app:layout_constraintBottom_toBottomOf="@id/topBookStage"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/topBookStage"
                    app:tint="@color/primary_color" />

                <LinearLayout
                    android:id="@+id/topBookDots"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/featuredSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="22dp"
                android:paddingEnd="24dp"
                app:layout_constraintTop_toBottomOf="@id/blueHeaderBg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/noto_serif_bold"
                        android:text="Featured Books"
                        android:textColor="@color/card_dark"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/tvViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_regular"
                        android:text="View All"
                        android:textColor="@color/secondary_color"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/featuredBooksList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/storeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="16dp"
                android:paddingEnd="24dp"
                app:layout_constraintTop_toBottomOf="@id/featuredSection">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/noto_serif_bold"
                    android:text="Our Stores Locations"
                    android:textColor="@color/card_dark"
                    android:textSize="17sp" />

                <FrameLayout
                    android:id="@+id/storeCarouselCard"
                    android:layout_width="match_parent"
                    android:layout_height="208dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_store_card"
                    android:clipToOutline="true"
                    android:elevation="4dp">

                    <ViewFlipper
                        android:id="@+id/storeFlipper"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <ImageButton
                        android:id="@+id/btnPrevStore"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_circle_button_dark"
                        android:contentDescription="Previous store"
                        android:padding="8dp"
                        android:src="@drawable/ic_chevron_left"
                        app:tint="@color/light_text" />

                    <ImageButton
                        android:id="@+id/btnNextStore"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_circle_button_dark"
                        android:contentDescription="Next store"
                        android:padding="8dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/light_text" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/storeDots"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:orientation="horizontal" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/footerBrand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="62dp"
                android:paddingEnd="62dp"
                app:layout_constraintTop_toBottomOf="@id/storeSection">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#D6D0C4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="@font/noto_serif_medium"
                    android:text="D'Classics Books"
                    android:textColor="@color/dark_text"
                    android:textSize="10sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#D6D0C4" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="242dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/primary_color"
        android:fitsSystemWindows="false"
        app:headerLayout="@layout/nav_header"
        app:itemBackground="@android:color/transparent"
        app:itemHorizontalPadding="24dp"
        app:itemIconTint="@color/accent_color"
        app:itemTextAppearance="@style/NavDrawerItemText"
        app:itemTextColor="@color/light_text"
        app:itemVerticalPadding="10dp"
        app:menu="@menu/sidebar_menu" />
</androidx.drawerlayout.widget.DrawerLayout>

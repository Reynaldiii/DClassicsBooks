<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:orientation="vertical"
    tools:context=".BookDetailActivity">

    <include
        android:id="@+id/detailHeader"
        layout="@layout/layout_app_header"
        android:layout_width="match_parent"
        android:layout_height="88dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="46dp">

            <FrameLayout
                android:id="@+id/detailHero"
                android:layout_width="match_parent"
                android:layout_height="235dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="172dp"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/imgHeroBook"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Book hero image"
                            android:scaleType="centerCrop" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#33000C1E" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_circle_button_dark"
                    android:contentDescription="Back"
                    android:padding="10dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@color/light_text" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/detailCoverCard"
                    android:layout_width="122dp"
                    android:layout_height="158dp"
                    android:layout_gravity="center_horizontal|bottom"
                    android:layout_marginBottom="0dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="5dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:id="@+id/imgBookCover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Book cover"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/detailContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingTop="10dp"
                android:paddingEnd="32dp">

                <TextView
                    android:id="@+id/tvBookTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/noto_serif_bold"
                    android:gravity="center"
                    android:maxLines="2"
                    android:textColor="@color/card_dark"
                    android:textSize="18sp"
                    tools:text="Rich Dad Poor Dad" />

                <TextView
                    android:id="@+id/tvBookAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/manrope_regular"
                    android:gravity="center"
                    android:maxLines="1"
                    android:textColor="#827D76"
                    android:textSize="12sp"
                    tools:text="Robert Kiyosaki" />

                <TextView
                    android:id="@+id/tvBookMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/manrope_regular"
                    android:textColor="#9A9284"
                    android:textSize="10sp"
                    tools:text="44.3k views | 4.9" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/noto_serif_bold"
                    android:text="Best Selling 2026"
                    android:textColor="@color/card_dark"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvBookDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/manrope_regular"
                    android:maxLines="6"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/dark_text"
                    android:textSize="12sp"
                    tools:text="A timeless story selected by D'Classics Books for readers who enjoy thoughtful, memorable literature." />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="34dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Your Address"
                    android:textColor="@color/card_dark"
                    android:textSize="15sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_location_pin"
                    app:startIconTint="@null">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAddress"
                        style="@style/Placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_rounded_input"
                        android:hint="Street, City, Province"
                        android:inputType="textPostalAddress"
                        android:textColor="@color/dark_text"
                        android:paddingStart="48dp"
                        android:paddingEnd="16dp"
                        android:textColorHint="#BDB8B0" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Phone Number"
                    android:textColor="@color/card_dark"
                    android:textSize="15sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_phone"
                    app:startIconTint="@null">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhone"
                        style="@style/Placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_rounded_input"
                        android:hint="+62 XXXXXXXXXX"
                        android:inputType="phone"
                        android:paddingStart="48dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/dark_text"
                        android:textColorHint="#AAAAAA" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuy"
                    style="@style/ButtonLabels"
                    android:layout_width="124dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="40dp"
                    android:text="BUY NOW"
                    android:textColor="@color/light_text"
                    app:backgroundTint="@color/btn_buy_selector"
                    app:cornerRadius="24dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
